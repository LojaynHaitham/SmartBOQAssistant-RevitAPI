		<Assembly>NGU.Lab13.Net8.dll</Assembly>
		<AddInId>a1b2c3d4-0001-0001-0001-000000000099</AddInId>
		<VendorId>NGU</VendorId>
		<VendorDescription>NGU Labs</VendorDescription>
